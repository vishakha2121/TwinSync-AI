.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*
.\#*

# ============================================
# OS FILES
# ============================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# Linux
.directory
*.directory
.directory_acl
*-lock
*.pid
*.lock

# ============================================
# LOGS
# ============================================

logs/
*.log
*.pid
*.tmp
*.temp

# Access logs
access.log
error.log
app.log

# ============================================
# SECRETS & CONFIGURATION
# ============================================

# Sensitive files
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.csr
*.secret
*.secure
*.private
*.pub.private

# Configuration files with secrets
config.local.*
*.local.yaml
*.local.yml
*.local.json
*.local.toml
secrets.*
secrets/

# API keys
.env.secrets
.env.keys
api-keys.txt

# ============================================
# DATA FILES
# ============================================

# Sample data files
*.csv
*.xlsx
*.xls
*.json
*.ndjson
*.parquet
*.feather
*.pickle

# Data directories
data/
datasets/
samples/
examples/

# Model files
*.h5
*.pb
*.onnx
*.pt
*.pth
*.ckpt
*.safetensors
*.tflite
*.pkl

# ============================================
# TEMPORARY FILES
# ============================================

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.cache
*.bak
*.backup
*.old
*.orig

# ============================================
# PROJECT SPECIFIC
# ============================================

# Auto-generated files
auto_generated/
generated/
compiled/

# Uploads
uploads/
media/
files/

# Static files
staticfiles/
static/

# Migration files (if using automatic generation)
**/migrations/*.py
!**/migrations/__init__.py
**/migrations/*.pyc
**/migrations/*.pyo

# Alembic
alembic/versions/*.py
!alembic/versions/__init__.py
*.pyc

# ============================================
# DEPLOYMENT
# ============================================

# Deployment artifacts
deploy/
deployment/
*.deploy
*.deployed

# Terraform
*.tfstate
*.tfstate.*
.terraform/

# Kubernetes
*.kubeconfig
*/.kube/
*.secret.yaml
*.secrets.yaml

# ============================================
# BUILD TOOLS
# ============================================

# Make
*.out
*.o
*.so

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ============================================
# EXCEPTIONS (What to keep)
# ============================================

# Keep these files even if in ignore patterns
!.gitignore
!.env.example
!.dockerignore
!.pre-commit-config.yaml
!.github/
!*.md
!*.rst
!LICENSE
!Dockerfile
!docker-compose.yml
!docker-compose.*.yml
!Makefile

